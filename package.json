{
  "name": "nexape",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:server": "npm run -w apps/server dev",
    "dev:web": "npm run -w apps/web dev",
    "build": "npm run -w packages/shared build && npm run -w apps/server build && npm run -w apps/web build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
